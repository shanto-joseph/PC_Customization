# Django Configuration
SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
DB_NAME=pc_shop
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_HOST=localhost
DB_PORT=3306

# Razorpay Payment Gateway
# Get your keys from: https://razorpay.com/ (test mode)
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET

# Google Gemini AI (Chatbot)
# Get free API keys from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_primary_gemini_api_key_here
GEMINI_API_KEY_BACKUP=your_backup_gemini_api_key_here
GEMINI_API_KEY_BACKUP_2=your_second_backup_gemini_api_key_here

